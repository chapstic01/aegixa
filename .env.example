# Discord Bot Token — from https://discord.com/developers/applications
DISCORD_TOKEN=

# OAuth2 credentials — from your application's OAuth2 page
CLIENT_ID=
CLIENT_SECRET=

# Your Railway public URL (no trailing slash), e.g. https://aegixa.up.railway.app
# Used as the OAuth2 redirect URI base
BASE_URL=https://your-app.up.railway.app

# Your personal Discord user ID (right-click yourself → Copy User ID)
BOT_OWNER_ID=616165674896588830

# Random secret for Flask sessions — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional: path to SQLite database file (defaults to ./aegixa.db)
# DB_PATH=/data/aegixa.db

# Optional: port for the web dashboard (Railway sets PORT automatically)
# PORT=8080
