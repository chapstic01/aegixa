# Discord Bot Token — from https://discord.com/developers/applications
DISCORD_TOKEN=

# OAuth2 credentials — from your application's OAuth2 page
CLIENT_ID=
CLIENT_SECRET=

# Your Railway public URL (no trailing slash), e.g. https://aegixa.up.railway.app
# Used as the OAuth2 redirect URI base
BASE_URL=https://your-app.up.railway.app

# Your personal Discord user ID (right-click yourself → Copy User ID)
BOT_OWNER_ID=616165674896588830

# Random secret for Flask sessions — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional: path to SQLite database file (defaults to ./aegixa.db)
# DB_PATH=/data/aegixa.db

# Optional: port for the web dashboard (Railway sets PORT automatically)
# PORT=8080

# Bot invite URL shown on the landing page
# Generate at: https://discord.com/developers/applications → OAuth2 → URL Generator
# Scopes: bot + applications.commands  |  Permissions: Administrator (or 8)
BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_CLIENT_ID&permissions=8&scope=bot%20applications.commands

# Gumroad product URL for the Premium buy button
PREMIUM_URL=https://example.gumroad.com/l/aegixa

# Your support Discord server invite
SUPPORT_SERVER=https://discord.gg/example

# Price shown on the landing page pricing card (display only, no payment logic)
PREMIUM_PRICE=2.99

# ---- Gumroad webhook (for automatic license key delivery) ----
# Random secret you add to the webhook URL in Gumroad
# e.g. https://your-app.up.railway.app/webhooks/gumroad?token=THIS_VALUE
WEBHOOK_SECRET=change-me-to-something-random

# Your Gumroad seller ID — find it at gumroad.com/settings/advanced
GUMROAD_SELLER_ID=

# ---- Email (SMTP) — for sending license keys to buyers ----
# Gmail: use an App Password (myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Aegixa <you@gmail.com>
